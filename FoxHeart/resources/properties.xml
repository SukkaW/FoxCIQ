<resources>
    <properties>
        <property id="zoneSystem" type="number">0</property>
        <property id="frielHrMethod" type="number">0</property>
        <property id="lthr" type="number">170</property>
        <property id="manualMaxHr" type="number">0</property>
    </properties>

    <settings>
        <setting propertyKey="@Properties.zoneSystem" title="@Strings.zoneSystem_title">
            <settingConfig type="list">
                <listEntry value="0">@Strings.zoneGarmin</listEntry>
                <listEntry value="1">@Strings.zoneFriel</listEntry>
            </settingConfig>
        </setting>
        <setting propertyKey="@Properties.frielHrMethod" title="@Strings.frielHrMethod_title">
            <settingConfig type="list">
                <listEntry value="0">@Strings.methodLthr</listEntry>
                <listEntry value="1">@Strings.methodMaxHr</listEntry>
                <listEntry value="2">@Strings.methodHrr</listEntry>
            </settingConfig>
        </setting>
        <setting propertyKey="@Properties.lthr" title="@Strings.lthr_title">
            <settingConfig type="numeric" min="100" max="220" />
        </setting>
        <setting propertyKey="@Properties.manualMaxHr" title="@Strings.manualMaxHr_title">
            <settingConfig type="numeric" min="0" max="230" />
        </setting>
    </settings>
</resources>
