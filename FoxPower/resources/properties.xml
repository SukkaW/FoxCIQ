<resources>
    <properties>
        <property id="zoneSystem" type="number">1</property>
        <property id="manualFtp" type="number">0</property>
        <property id="zoneBarHeight" type="number">4</property>
        <property id="zoneIndexHeight" type="number">4</property>
    </properties>

    <settings>
        <setting propertyKey="@Properties.zoneSystem" title="@Strings.zoneSystem_title">
            <settingConfig type="list">
                <listEntry value="0">@Strings.zoneGarmin</listEntry>
                <listEntry value="1">@Strings.zoneFriel</listEntry>
            </settingConfig>
        </setting>
        <setting propertyKey="@Properties.manualFtp" title="@Strings.manualFtp_title">
            <settingConfig type="numeric" min="0" max="600" />
        </setting>
        <setting propertyKey="@Properties.zoneBarHeight" title="@Strings.zoneBarHeight_title">
            <settingConfig type="numeric" min="0" max="15" />
        </setting>
        <setting propertyKey="@Properties.zoneIndexHeight" title="@Strings.zoneIndexHeight_title">
            <settingConfig type="numeric" min="0" max="15" />
        </setting>
    </settings>
</resources>
